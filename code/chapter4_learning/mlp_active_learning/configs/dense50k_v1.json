    "optimizer": "Adam",
    "lr": 0.003,
    "weight_decay": 0.001,
    "batch_size": 32,
    "max_epochs": 160,
    "patience": 22,
    "val_fraction": 0.15
  },
  "acquisition": {
    "ensemble_size": 5,
    "hybrid_weights": {
      "model_uncertainty": 0.30,
      "ensemble_disagreement": 0.20,
      "formula_margin_proximity": 0.25,
      "blocked_targeting": 0.15,
      "inward_movement_targeting": 0.10
    },
    "diverse_uncertainty": {
      "preselect_top_n": 3000,
      "score_weight": 0.70,
      "diversity_weight": 0.30
    }
  },
  "pool_generation": {
    "proposal_distribution": "rejection-conditioned smart_sampler mix",
    "stream_mix": "seed%5 -> uniform/boundary/extreme/lhs/uniform",
    "seed_base": 550001,
    "holdout_exclusion": true
  },
  "geometry_version": "Task 24 corrected (D5 outer wall, D7, slack-aware D4, 5% head lengths)",
  "oracle": "chapter3_clevis_setup.exact_assemblability",
  "parallelization": {
    "pool_workers": 16,
    "grid_workers": 12,
    "per_worker_threads": 1
  }
