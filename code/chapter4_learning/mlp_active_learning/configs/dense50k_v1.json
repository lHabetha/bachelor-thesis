{
  "experiment_name": "dense50k_v1",
  "description": "Task 22 label-efficiency rerun with 50k candidate pool",
  "candidate_pool_size": 50000,
  "holdout_size": 5000,
  "holdout_source": "datasets/chapter4_clevis_pools/holdout/holdout.parquet",
  "t_max": 3500,
  "step_size": 250,
  "base_sizes": [0, 250, 500, 750, 1000, 1500, 2000, 2500],
  "seed_splits": 8,
  "rows": ["row1_pure_hybrid", "row2_hybrid_diverse_half"],
  "baseline_replicates": 5,
  "model": {
    "architecture": "MLP 13->64->32->1",
    "activation": "ReLU",
    "dropout": 0.1,
    "loss": "BCEWithLogitsLoss",
